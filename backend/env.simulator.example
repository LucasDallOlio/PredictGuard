# ============================================================================
# ARQUIVO DE CONFIGURAÇÃO DO SIMULADOR ESP32
# Copie como .env para usar com: npm run simulate:esp32
# ============================================================================

# ============================================================================
# Configurações MQTT — Broker
# ============================================================================
MQTT_BROKER_URL=mqtt://127.0.0.1
MQTT_PORT=1883
MQTT_CLIENT_ID=esp32_simulator

# Tópicos MQTT (suportam placeholders: {sensorId}, {sensorTempId}, {sensorVibraId})
MQTT_TOPIC_TEMP=motor/temperatura/{sensorTempId}
MQTT_TOPIC_VIBRA=motor/vibracao/{sensorVibraId}

# ============================================================================
# Configurações do Simulador
# ============================================================================

# Intervalo de publicação em milissegundos
MQTT_PUBLISH_INTERVAL_MS=1000

# IDs dos sensores de temperatura a simular (separados por vírgula)
# Exemplo: 1,3,5,7
SIM_TEMP_SENSOR_IDS=1,3

# IDs dos sensores de vibração a simular (separados por vírgula)
# Exemplo: 2,4,6,8
SIM_VIBRA_SENSOR_IDS=2,4

# Compatibilidade legada: mantém a simulação por máquina caso os IDs por sensor não sejam informados
SIM_DEVICE_IDS=

# ============================================================================
# Parâmetros de Temperatura (°C)
# ============================================================================
SIM_TEMP_BASE=70.0                    # Temperatura base de cada máquina
SIM_TEMP_NOISE=1.5                    # Ruído aleatório em cada leitura
SIM_TEMP_DRIFT=0.02                   # Deriva gradual ao longo do tempo
SIM_TEMP_BASE_JITTER=3.0              # Variação inicial entre máquinas
SIM_TEMP_SPIKE_PROB=0.02              # Probabilidade de pico por ciclo (2%)
SIM_TEMP_SPIKE_MAX=8.0                # Amplitude máxima do pico
SIM_TEMP_SPIKE_DURATION_MS=8000       # Duração do pico em ms

# ============================================================================
# Parâmetros de Vibração (mm/s)
# ============================================================================
SIM_VIBRA_BASE=2.0                    # Vibração base de cada máquina
SIM_VIBRA_NOISE=0.25                  # Ruído aleatório em cada leitura
SIM_VIBRA_BASE_JITTER=0.6             # Variação inicial entre máquinas
SIM_VIBRA_SPIKE_PROB=0.04             # Probabilidade de pico por ciclo (4%)
SIM_VIBRA_SPIKE_MAX=6.0               # Amplitude máxima do pico
SIM_VIBRA_SPIKE_DURATION_MS=5000      # Duração do pico em ms
